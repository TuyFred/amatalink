{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://amatalink.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
